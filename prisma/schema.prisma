generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

// --- Enums ---
enum Provenance {
  FACT
  INFERRED
}

enum ReviewLabel {
  PRAISE
  COMPLAINT
  REQUEST
  INQUIRY
  NEUTRAL
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum CompanionType {
  SOLO
  COUPLE
  FAMILY
  GROUP
  UNKNOWN
}

enum TopicType {
  FOOD
  ROOM
  BATH
  SERVICE
  LOCATION
  OTHER
}

enum Role {
  OWNER
  MEMBER
}

// --- Models ---

// 1. 組織（クライアント・ワークスペース単位のデータ所有者）
model Organization {
  id        String   @id @default(cuid())
  name      String
  createdAt DateTime @default(now())

  members OrganizationMember[]
  reviews Review[]
}

// 2. ログインユーザー（Clerk の userId を id として使用）
model User {
  id        String   @id
  email     String   @unique
  name      String?  @map("hotel_name")
  createdAt DateTime @default(now())

  memberships OrganizationMember[]
}

// 3. 組織とユーザーの中間テーブル（メンバーシップ・権限管理）
model OrganizationMember {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  role           Role     @default(MEMBER)
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
}

// 4. 口コミの事実データ (Aggregate Root)
model Review {
  id             String       @id @default(uuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  reviewUrl      String?
  overallRating  Int
  postedAt       DateTime

  sourceReviewId String
  reviewerName   String
  sourceUserId   String?
  avatarUrl      String?

  createdAt DateTime @default(now())

  sentences Sentence[]
  analysis  ReviewAnalysis?
  topics    TopicEvaluation[]

  @@unique([organizationId, sourceReviewId])
}

// 5. 分割された文 (Tokenized Sentences)
model Sentence {
  id       String @id @default(uuid())
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  sequenceNum    Int
  originalText   String
  translatedText String?

  @@unique([reviewId, sequenceNum])
}

// 6. LLMによる推論・属性データ (1対1)
model ReviewAnalysis {
  id       String @id @default(uuid())
  reviewId String @unique
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  primaryLanguage    String
  secondaryLanguages String[]

  nationalityValue  String
  nationalityProv   Provenance
  nationalityConf   Float?
  nationalityReason String?

  genderValue  Gender
  genderProv   Provenance
  genderConf   Float?
  genderReason String?

  companionValue  CompanionType
  companionProv   Provenance
  companionConf   Float?
  companionReason String?

  overallLabelValue  ReviewLabel
  overallLabelProv   Provenance
  overallLabelConf   Float?
  overallLabelReason String?
}

// 7. トピックごとのアスペクト分析 (1対多)
model TopicEvaluation {
  id       String @id @default(uuid())
  reviewId String
  review   Review @relation(fields: [reviewId], references: [id], onDelete: Cascade)

  topic  TopicType
  label  ReviewLabel
  rating Int

  evidenceSequenceNums Int[]
}
