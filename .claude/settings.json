{
  "allowedTools": ["*"],
  "bash": {
    "deny": [
      "rm -rf /",
      "rm -rf /*",
      "mkfs",
      "dd",
      "chmod 777",
      "chmod -R 777",
      "chown",
      "curl",
      "wget",
      "nc",
      "netcat",
      "nmap",
      "ssh",
      "scp",
      "sftp",
      "ftp",
      "telnet",
      "ping",
      "traceroute",
      "npm publish",
      "git push --force",
      "cat .env",
      "cat .env.local",
      "cat .env.development",
      "cat .env.production",
      "less .env",
      "more .env",
      "tail .env",
      "head .env",
      "nano .env",
      "vim .env",
      "vi .env",
      "grep .env",
      "awk .env",
      "sed .env",
      "printenv",
      "env",
      "set",
      "history -c",
      "> /dev/null"
    ]
  }
}
